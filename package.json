{
  "name": "f1stories-site",
  "version": "1.0.0",
  "description": "F1 Stories static website — build scripts for the blog publishing pipeline.",
  "private": true,
  "scripts": {
    "build": "npm run build:html && npm run build:youtube && npm run build:blog && npm run build:assets",
    "build:blog": "node blog-module/build/index.js",
    "build:blog:force": "node blog-module/build/index.js --force",
    "build:html": "node scripts/build/include.mjs",
    "build:logo": "node scripts/build/optimize-logo.mjs",
    "build:driver-headshots": "node scripts/build/fetch-driver-headshots.mjs",
    "build:team-logos": "node scripts/build/fetch-team-logos.mjs",
    "build:youtube": "node scripts/build/fetch-youtube.mjs",
    "build:standings-data": "node scripts/build/refresh-standings-data.mjs",
    "build:images": "npm run build:logo && npm run build:driver-headshots && npm run build:team-logos",
    "build:article-image-backfill": "node scripts/build/backfill-article-image-attrs.mjs",
    "build:image-variants": "node blog-module/generate-image-variants.js --run",
    "build:fonts": "node scripts/build/download-fonts.mjs",
    "build:icons": "node scripts/build/build-icon-sprite.mjs",
    "build:bootstrap": "sass styles/vendor/bootstrap.slim.scss styles/vendor/bootstrap.slim.css --style=compressed --no-source-map",
    "build:assets": "node scripts/build/build-icon-sprite.mjs && npm run build:bootstrap && node scripts/build/minify.mjs && node scripts/build/stamp-html.mjs",
    "build:assets:minify": "node scripts/build/minify.mjs",
    "build:assets:stamp": "npm run build:html && node scripts/build/stamp-html.mjs",
    "build:assets:watch": "node scripts/build/minify.mjs --watch",
    "build:public": "npm run pages:guard && npm run build && node scripts/build/public-artifact.mjs && node scripts/build/validate-public-artifact.mjs",
    "build:check": "node scripts/build/generated-drift-guard.mjs",
    "test:blog": "node blog-module/build/__tests__/run-golden.js",
    "test:author": "node --test scripts/author/__tests__/*.test.mjs",
    "pages:guard": "node scripts/build/pages-source-guard.mjs",
    "quality:rendering": "node scripts/quality/rendering-sink-guard.mjs",
    "quality:rendering:update": "node scripts/quality/rendering-sink-guard.mjs --update",
    "quality:static": "node scripts/quality/static-source-guard.mjs && npm run quality:rendering",
    "audit:runtime": "node scripts/quality/runtime-audit.mjs",
    "perf:budget": "node scripts/perf/size-guard.mjs",
    "perf:budget:update": "node scripts/perf/size-guard.mjs --update",
    "perf:article-media": "node scripts/perf/article-media-guard.mjs",
    "perf:article-media:update": "node scripts/perf/article-media-guard.mjs --update",
    "perf:images": "node scripts/perf/public-image-guard.mjs",
    "qa:visual": "node scripts/perf/visual-qa.mjs",
    "test:consent": "node scripts/perf/consent-guard.mjs",
    "perf:lighthouse": "node scripts/perf/lighthouse-guard.mjs",
    "verify": "npm run build:public && npm run build:check && npm run quality:static && npm run audit:runtime && npm run test:blog && npm run test:author && npm run perf:budget && npm run perf:article-media && npm run perf:images && npm run test:consent && npm run perf:lighthouse"
  },
  "dependencies": {
    "adm-zip": "^0.5.12",
    "mammoth": "^1.8.0",
    "sharp": "^0.33.5"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^6.5.1",
    "bootstrap": "^5.3.8",
    "chrome-launcher": "^1.2.1",
    "esbuild": "^0.25.12",
    "fast-xml-parser": "^5.7.1",
    "lighthouse": "^12.8.2",
    "lightningcss": "^1.32.0",
    "puppeteer-core": "^24.43.1",
    "sass": "^1.99.0"
  }
}
