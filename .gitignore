# macOS
.DS_Store
**/.DS_Store

# Generated build output — images are served directly from blog-entries/
blog-module/blog/images/

# Node
node_modules/
npm-debug.log*

# Temp extraction folder (cleaned up by processor, but just in case)
blog-module/blog-entries/*/extracted/

# Source documents — not needed on the web server
blog-module/blog-entries/**/*.docx

# Generated responsive image variants (produced by generate-image-variants.js)
# Excluded from git — regenerated from the tracked WebP source files
blog-module/blog-entries/*/*.avif
blog-module/blog-entries/*/*-sm.webp
blog-module/blog-entries/*/*-sm.avif
